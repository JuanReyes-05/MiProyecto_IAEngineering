#API OpenAI
OPENAI_API_KEY=aqui-va-tu-api-key
MODEL_NAME=name-model
#OPENAI_BASE_URL=None

# Score mínimo de confianza para responder directamente (0.0 - 1.0)
# Si el score es menor, la respuesta indicará que no tiene suficiente info
MINIMUM_SCORE=0.60

# Configuración del servidor
HOST=0.0.0.0
PORT=8000

# Modelo de embeddings de HuggingFace (recomienda uno multilingüe para soporte en español)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Carpeta donde se guardan los documentos a ingestar
DOCS_DIR=./docs

# Carpeta donde se guarda la base de datos vectorial (ChromaDB)
CHROMA_DIR=./chroma_db

# Nombre de la colección en ChromaDB
COLLECTION_NAME=soporte_docs

# Configuración de chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# Cuántos fragmentos recuperar por consulta (top-K)
TOP_K=4